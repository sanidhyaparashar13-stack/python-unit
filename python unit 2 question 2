class Library:
    def __init__(self, book_name, author):
        self.book_name = book_name
        self.author = author
        self.available = True

    def checkout(self):
        if self.available:
            self.available = False
            print("Book issued")
        else:
            print("Not available")

    def return_book(self):
        self.available = True
        print("Book returned")

    def status(self):
        print("Available:", self.available)

# Example
b = Library("Python", "ABC")
b.checkout()
b.status()
b.return_book()
